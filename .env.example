# Cloudflare Tunnel token (deploy)
TUNNEL_TOKEN=your_tunnel_token_here

# Secret used to sign account session tokens (JWT). REQUIRED.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# How long a login stays valid before re-authenticating (Go duration). Optional.
JWT_TTL=720h

# Set to true to close public sign-up (login still works). Optional.
DISABLE_REGISTRATION=false

# Postgres credentials. Optional — sensible defaults are baked into compose.
POSTGRES_USER=root
POSTGRES_PASSWORD=rootpassword
POSTGRES_DB=cartografo_db
